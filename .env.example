# Env vars for an ephemeral demo deployment (Phase 11 — see README.md's
# "Deploying the demo" section and PLAN.md). This is deliberately NOT the full
# .env.example — a real self-hosted instance (your own data) uses that one instead.
#
# These 4 are the only ones the demo actually needs:
ENABLE_DEMO_LOGIN=true
AUTH_MODE=enabled
DEMO_CAPACITY=5
DEMO_SESSION_HOURS=2

# Everything in .env.example (Strava/Garmin/Claude/VAPID credentials) is unused in
# demo mode — real Strava/Garmin syncs and the AI chat are both mocked for demo users
# (see app/demo.py), and the frontend hides the controls that would otherwise ask for
# them. If your host's deploy form auto-detects .env.example and insists on non-empty
# values for those anyway (some do — they scan the file, not the actual code), any
# placeholder text works:
#   STRAVA_CLIENT_ID=unused
#   STRAVA_CLIENT_SECRET=unused
#   GARMIN_EMAIL=unused@example.com
#   GARMIN_PASSWORD=unused
#   CLAUDE_CODE_OAUTH_TOKEN=unused
#   ANTHROPIC_API_KEY=unused
#   VAPID_PUBLIC_KEY=unused
#   VAPID_PRIVATE_KEY=unused
