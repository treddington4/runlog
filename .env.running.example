# Create a Strava API app at https://www.strava.com/settings/api
# "Authorization Callback Domain" should be: localhost
STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback

# How often to auto-sync (hours)
SYNC_INTERVAL_HOURS=6
SYNC_ACTIVITY_LIMIT=10

# OPTIONAL — unofficial Garmin sync. Leave blank to skip.
# Uses your real Garmin login via the unofficial `garminconnect` library.
# This can break without warning since it's not an official API.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Set to DEBUG for verbose per-call sync logging (login path, activity counts, skip
# decisions, cooldown state, batch pauses) — visible via `docker logs`. Defaults to INFO.
LOG_LEVEL=INFO

# OPTIONAL — Garmin sync pacing tuning. Defaults are conservative given how easily the
# unofficial API rate-limits this session found; only change these if you know what
# you're doing. GARMIN_DETAIL_BATCH_SIZE activities are fetched before pausing
# GARMIN_BATCH_PAUSE_SEC seconds. After any real rate-limit hit, a separate cooldown
# blocks new sync attempts entirely, starting at GARMIN_COOLDOWN_BASE_SEC and doubling
# per consecutive failure up to GARMIN_COOLDOWN_MAX_SEC.
GARMIN_DETAIL_BATCH_SIZE=5
GARMIN_BATCH_PAUSE_SEC=300
GARMIN_COOLDOWN_BASE_SEC=300
GARMIN_COOLDOWN_MAX_SEC=14400
GARMIN_STEPS_VOLATILE_DAYS=2

# OPTIONAL — AI chat assistant (Chat tab). Leave both blank to disable it; you can add
# either one later and just restart the container, no code changes needed. Set at most
# one — if both are set, the SDK's own default precedence picks ANTHROPIC_API_KEY.
#
# Subscription mode (uses your existing Claude Pro/Max plan, no per-token billing):
# on any machine with Node 18+, run `npm install -g @anthropic-ai/claude-code` then
# `claude setup-token`, complete the browser login, and paste the printed token below.
# It's long-lived (~1 year) — you won't need to redo this often.
CLAUDE_CODE_OAUTH_TOKEN=
# API key mode (standard metered pay-as-you-go billing): generate one at
# console.anthropic.com and paste it below instead.
ANTHROPIC_API_KEY=

# OPTIONAL — Web Push (PWA push notifications). Leave blank to disable; the Settings
# toggle degrades cleanly with no code changes needed, same as the Chat assistant above.
# Generate a keypair once with:
#   pip install py-vapid && python -c "
#   from py_vapid import Vapid02; import base64
#   from cryptography.hazmat.primitives.serialization import Encoding, PublicFormat
#   v = Vapid02(); v.generate_keys()
#   raw_pub = v.public_key.public_bytes(Encoding.X962, PublicFormat.UncompressedPoint)
#   print('VAPID_PUBLIC_KEY=' + base64.urlsafe_b64encode(raw_pub).rstrip(b'=').decode())
#   priv = v.private_key.private_numbers().private_value.to_bytes(32, 'big')
#   print('VAPID_PRIVATE_KEY=' + base64.urlsafe_b64encode(priv).rstrip(b'=').decode())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:you@example.com
